# ─── Clerk (authentication) ─────────────────────────────────────────────
# Sign up at https://clerk.com, create an app, and paste keys here.
# Then wrap the app in <ClerkProvider> in src/app/layout.tsx and add middleware.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Supabase (database / cross-device progress) ────────────────────────
# Create a project at https://supabase.com and copy the values from
# Project Settings → API. See README → "Wiring up Clerk + Supabase".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Mentor (optional real LLM) ──────────────────────────────────────
# The mentor works out-of-the-box offline (built-in beginner-friendly answers).
# Add a key here to upgrade it to a REAL Claude tutor — the /api/mentor route
# picks it up automatically, no code change needed. On Vercel, add this under
# Project Settings → Environment Variables. Model is set in src/app/api/mentor/
# route.ts (default: claude-haiku-4-5 for fast, cheap replies).
ANTHROPIC_API_KEY=
