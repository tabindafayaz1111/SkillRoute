# ─── Clerk (authentication) ─────────────────────────────────────────────
# Sign up at https://clerk.com, create an app, and paste keys here.
# Then wrap the app in <ClerkProvider> in src/app/layout.tsx and add middleware.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ─── Supabase (database / cross-device progress) ────────────────────────
# Create a project at https://supabase.com and copy the values from
# Project Settings → API. See README → "Wiring up Clerk + Supabase".
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── AI Mentor (optional real LLM) ──────────────────────────────────────
# To upgrade the mentor from rule-based to a real Claude tutor, add a key and
# implement /api/mentor (see src/lib/mentor.ts). Recommended: claude-opus-4-8.
ANTHROPIC_API_KEY=
